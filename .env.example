# Cloudflare Workers Environment Configuration Example
# Copy this file and update with your actual values

# Database
# Get your DATABASE_ID from: https://dash.cloudflare.com/?to=/:account/workers/d1
DATABASE_ID=your_database_id_here

# Admin Password (used to login to /admin/)
ADMIN_PASSWORD=your-secure-password-here

# Optional: Email Service Configuration
# Uncomment and fill in the email service you want to use

# --- Resend Configuration (Recommended - Free tier: 100 emails/day) ---
# RESEND_API_KEY=your_resend_api_key_here
# FROM_EMAIL=noreply@yourdomain.com

# --- SendGrid Configuration (Free tier: 20,000 emails/month) ---
# SENDGRID_API_KEY=your_sendgrid_api_key_here
# FROM_EMAIL=noreply@yourdomain.com

# --- Mailgun Configuration (Free tier: 1,000 emails/month) ---
# MAILGUN_API_KEY=your_mailgun_api_key_here
# MAILGUN_DOMAIN=your_mailgun_domain

# Application Settings
ENVIRONMENT=production
# Set to 'development' for local testing
