# Cloudflare Workers Environment Configuration Example
# Copy this file and update with your actual values

# Database
# Get your DATABASE_ID from: https://dash.cloudflare.com/?to=/:account/workers/d1
DATABASE_ID=your_database_id_here

# Admin Password (used to login to /admin/)
ADMIN_PASSWORD=your-secure-password-here

# Session signing secret (recommended; separate from your login password)
SESSION_SECRET=your-long-random-session-secret-here

# Optional: Brevo email sending
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Beplugged Tech
BREVO_REPLY_TO=hello@yourdomain.com

# Application Settings
ENVIRONMENT=production
# Set to 'development' for local testing
